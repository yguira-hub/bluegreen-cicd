pipeline {
    agent any
    environment {
        APP_VM_IP   = "192.168.64.8"
        APP_VM_USER = "yuss"
    }
    stages {
        stage('Checkout') {
            steps { checkout scm }
        }
        stage('Test') {
            steps {
                sh 'echo "Running tests..."'
                sh 'cat app/app.py | grep -q "health" && echo "Health endpoint OK"'
            }
        }
        stage('Build & Deploy') {
            steps {
                sshagent(['app-vm-ssh-key']) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${APP_VM_USER}@${APP_VM_IP} '
                            cd ~/bluegreen-cicd && git pull origin main
                            cd ~/bluegreen-cicd/app && docker compose up -d --build
                        '
                    """
                }
            }
        }
        stage('Switch to Green') {
            steps {
                sshagent(['app-vm-ssh-key']) {
                    sh "ssh -o StrictHostKeyChecking=no ${APP_VM_USER}@${APP_VM_IP} '~/bluegreen-cicd/scripts/switch.sh green'"
                }
            }
        }
        stage('Smoke Test') {
            steps {
                sshagent(['app-vm-ssh-key']) {
                    sh "ssh -o StrictHostKeyChecking=no ${APP_VM_USER}@${APP_VM_IP} 'curl -sf http://localhost/health | grep ok'"
                }
            }
            post {
                failure {
                    sshagent(['app-vm-ssh-key']) {
                        sh "ssh -o StrictHostKeyChecking=no ${APP_VM_USER}@${APP_VM_IP} '~/bluegreen-cicd/scripts/rollback.sh'"
                    }
                }
            }
        }
    }
    post {
        success { echo "✅ Deployment successful — Green is live" }
        failure { echo "❌ Pipeline failed — Rollback triggered" }
    }
}
